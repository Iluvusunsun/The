Main_Farm:Dropdown({
    Title = "Select Weapon",
    Values = {"Melee","Sword","Gun","Blox Fruit"},
    Default = Selected_Weapon or "Melee",
    Callback = function(v)
        Selected_Weapon = v
    end
})

Main_Farm:Dropdown({
    Title = "Select Mode",
    Values = {"Above","Behind"},
    Default = Selected_Mode_Farm or "Above",
    Callback = function(v)
        Selected_Mode_Farm = v
    end
})

Main_Farm:Slider({
    Title = "Distance",
    Step = 1,
    Value = {Min = 1, Max = 100, Default = Distance_Func or 20},
    Callback = function(v)
        Distance_Func = v
    end
})

