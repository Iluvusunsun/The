    Title = "Reset Character",
    Callback = function()
        game.Players.LocalPlayer.Character.Head:Destroy()
    end
})

Main_Farm:Button({
    Title = "Destroy All Effect",
    Callback = function()
        for _,v in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
            if v:IsA('ParticleEmitter') then v:Destroy() end
        end
        for _,v in pairs(workspace:GetDescendants()) do
            if v:IsA('ParticleEmitter') then v:Destroy() end
        end
    end
})

--// FARM

Main_Farm:Toggle({
    Title = "Auto Farm (Quest)",
    Default = Level_Quest_Func or false,
    Callback = function(v)
        Level_Quest_Func = v
        Main_Module.StopTween(v)
    end
})

Main_Farm:Toggle({
    Title = "Auto Farm (No Quest)",
    Default = Level_No_Quest_Func or false,
    Callback = function(v)
        Level_No_Quest_Func = v
        Main_Module.StopTween(v)
    end
})

Main_Farm:Toggle({
    Title = "Auto Farm (Nearest)",
    Default = Nearest_Farm_Func or false,
    Callback = function(v)
        Nearest_Farm_Func = v
        Main_Module.StopTween(v)
    end
})

Main_Farm:Toggle({
    Title = "Auto Farm Hearts",
    Default = Hearts_Farm_Func or false,
    Callback = function(v)
        Hearts_Farm_Func = v
        Main_Module.StopTween(v)
    end
})

task.spawn(function()
    while task.wait() do
        if Selected_Mode_Farm == "Above" then
            Farm_Mode = CFrame.new(0, Distance_Func, 0)
        elseif Selected_Mode_Farm == "Behind" then
            Farm_Mode = CFrame.new(0, 1, Distance_Func)
        end
    end
end)

task.spawn(function()
    while task.wait() do
        AutoShoot = AutoAttacks
    end
end)

task.spawn(function()
    while task.wait() do
        if Auto_Click_Func then
            Main_Module.Click(0.3)
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Ken_Haki_Func then
            if not game.Players.LocalPlayer.Character:FindFirstChild("Highlight") then
                game:service('VirtualInputManager'):SendKeyEvent(true,"E",false,game)
                task.wait(.1)
                game:service('VirtualInputManager'):SendKeyEvent(false,"E",false,game)
            end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Buso_Haki_Func then
            if not game.Players.LocalPlayer.Character:FindFirstChild("HasBuso") then
                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Buso")
            end
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Spawn_Point_Func then
            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("SetSpawnPoint")
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if AudioDamage_Func then
            for _,v in pairs(workspace["_WorldOrigin"]:GetChildren()) do
                if v.Name == "Sounds" then
                    for _,v2 in pairs(v:GetChildren()) do
                        if v2:IsA("Part") then v2:Destroy() end
                    end
                end
                if table.find({"CurvedRing","SlashHit","SwordSlash","SlashTail","DamageCounter"}, v.Name) then
                    v:Destroy()
                end
            end
            game:GetService("ReplicatedStorage").Assets.GUI.DamageCounter.Size = UDim2.new(0,0,0,0)
        else
            game:GetService("ReplicatedStorage").Assets.GUI.DamageCounter.Size = UDim2.new(11,0,4,0)
        end
    end
end)

task.spawn(function()
    while task.wait() do
        if Hide_Notification_Func then
            for _,v in pairs(game.Players.LocalPlayer.PlayerGui.Notifications:GetChildren()) do
                v:Destroy()
            end
        end
    end
end)
